# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Qdrant Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents
QDRANT_DENSE_DIM=1024
QDRANT_SPARSE_DISTANCE=Dot
QDRANT_BATCH_SIZE=100
QDRANT_RETRY_MAX=3
QDRANT_RETRY_BACKOFF_BASE=1.0
QDRANT_SCHEMA_VERSION=1.0.0
QDRANT_API_KEY=  # Optional, for Qdrant Cloud

# LangSmith Tracing (Optional - for development)
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=crag-pipeline-dev

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# Ingestion Settings
MAX_FILE_SIZE_BYTES=52428800
WATCH_DIR=data/watch
